<UserControl x:Class="ProxiFyre.AnnouncementPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">
    <Border Padding="12"
            Background="#FFF7E6"
            BorderBrush="#FEDF89"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="公告"
                       FontWeight="SemiBold"
                       Foreground="#B54708"
                       Margin="0,0,10,0"
                       VerticalAlignment="Top" />
            <TextBlock x:Name="AnnouncementText"
                       Grid.Column="1"
                       Foreground="#7A4B00"
                       Margin="0,0,10,0"
                       TextWrapping="Wrap" />
            <Button Grid.Column="2"
                    Width="28"
                    Height="28"
                    MinHeight="28"
                    Padding="0"
                    BorderThickness="0"
                    Cursor="Hand"
                    Background="#FEEFC3"
                    ToolTip="关闭公告"
                    Click="CloseButton_Click"
                    VerticalAlignment="Top">
                <Path Width="10"
                      Height="10"
                      Fill="#B54708"
                      Stretch="Uniform"
                      Data="M 1 0 L 5 4 L 9 0 L 10 1 L 6 5 L 10 9 L 9 10 L 5 6 L 1 10 L 0 9 L 4 5 L 0 1 Z" />
            </Button>
        </Grid>
    </Border>
</UserControl>

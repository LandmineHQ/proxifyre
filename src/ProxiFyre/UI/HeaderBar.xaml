<UserControl x:Class="ProxiFyre.HeaderBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#667085" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D8DEE8" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#16803C" />

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ProxiFyre Direct Relay"
                               FontSize="21"
                               FontWeight="SemiBold"
                               Foreground="#1F2937" />
                    <Border Padding="8,3"
                            CornerRadius="10"
                            Background="#EEF2F7"
                            Margin="10,1,0,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="本地 " FontSize="11" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="LocalVersionText"
                                       Text="0.0.0"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#1F2937" />
                            <TextBlock Text=" / 远程 " FontSize="11" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="RemoteVersionText"
                                       Text="检查中"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <TextBlock Text="Direct traffic relay for selected Windows applications"
                           FontSize="12"
                           Foreground="{StaticResource MutedTextBrush}"
                           Margin="0,2,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Width="36"
                        Height="32"
                        Padding="0"
                        Margin="0,0,10,0"
                        Click="SourceButton_Click"
                        ToolTip="打开 GitHub 仓库"
                        Background="#EEF2F7"
                        Foreground="#1F2937">
                    <Path Width="18"
                          Height="18"
                          Fill="#24292F"
                          Stretch="Uniform"
                          Data="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.49.5.09.68-.22.68-.48 0-.24-.01-.87-.01-1.7-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.46-1.11-1.46-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.64-1.34-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.99 1.03-2.69-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.03A9.56 9.56 0 0 1 12 6.84c.85 0 1.71.11 2.5.34 1.91-1.29 2.75-1.03 2.75-1.03.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.69 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85 0 1.34-.01 2.42-.01 2.75 0 .27.18.58.69.48A10.01 10.01 0 0 0 22 12c0-5.52-4.48-10-10-10Z" />
                </Button>

                <Border x:Name="StatusBadge"
                        Padding="10,6"
                        CornerRadius="16"
                        Background="#EEF2F7"
                        Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot"
                                 Width="8"
                                 Height="8"
                                 Fill="#98A2B3"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="StatusText"
                                   Text="已暂停"
                                   FontWeight="SemiBold"
                                   Foreground="#475467" />
                    </StackPanel>
                </Border>

                <Button x:Name="StartStopButton"
                        Width="118"
                        Click="StartStopButton_Click"
                        Background="{StaticResource SuccessBrush}"
                        Foreground="White">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Path x:Name="StartStopIcon"
                              Width="14"
                              Height="14"
                              Fill="White"
                              Stretch="Uniform"
                              Data="M 2 1 L 13 7 L 2 13 Z"
                              Margin="0,0,8,0" />
                        <TextBlock x:Name="StartStopButtonText"
                                   Text="启用"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

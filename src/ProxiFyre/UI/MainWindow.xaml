<Window x:Class="ProxiFyre.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ProxiFyre Direct Relay" Height="660" Width="960"
        MinHeight="600" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/AppIcon.ico"
        Background="#F3F6FA">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#667085" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D8DEE8" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#16803C" />
        <SolidColorBrush x:Key="DangerBrush" Color="#C73535" />

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelStyle}" Padding="14" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="ProxiFyre Direct Relay" FontSize="21" FontWeight="SemiBold" Foreground="#1F2937" />
                    <TextBlock Text="Direct traffic relay for selected Windows applications"
                               FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="StatusBadge" Padding="10,6" CornerRadius="16" Background="#EEF2F7" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#98A2B3" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock x:Name="StatusText" Text="已暂停" FontWeight="SemiBold" Foreground="#475467" />
                        </StackPanel>
                    </Border>

                    <Button x:Name="StartStopButton"
                            Width="118"
                            Click="StartStopButton_Click"
                            Background="{StaticResource SuccessBrush}"
                            Foreground="White">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Path x:Name="StartStopIcon"
                                  Width="14" Height="14"
                                  Fill="White"
                                  Stretch="Uniform"
                                  Data="M 2 1 L 13 7 L 2 13 Z"
                                  Margin="0,0,8,0" />
                            <TextBlock x:Name="StartStopButtonText" Text="启用" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelStyle}" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="核心进程名" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4" />
                    <TextBox x:Name="CoreProcessNameInput"
                             ToolTip="用于核心进程自排除；默认 steamwebhelper.exe"
                             LostFocus="CoreProcessNameInput_LostFocus"
                             KeyDown="CoreProcessNameInput_KeyDown" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="自定义规则" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4" />
                    <TextBox x:Name="AppInput" ToolTip="例如 chrome.exe、完整 exe 路径，或目录路径" />
                </StackPanel>

                <Button Grid.Column="4" Content="添加" Click="AddButton_Click" VerticalAlignment="Bottom"
                        Background="#2563EB" Foreground="White" />
                <Button Grid.Column="6" Content="应用..." Click="BrowseButton_Click" VerticalAlignment="Bottom"
                        Background="#EEF2F7" Foreground="#1F2937" />
                <Button Grid.Column="8" Content="目录..." Click="BrowseDirectoryButton_Click" VerticalAlignment="Bottom"
                        Background="#EEF2F7" Foreground="#1F2937" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PanelStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TabControl>
                    <TabItem Header="应用规则">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="应用规则" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ElementName=AppsList, Path=Items.Count, StringFormat={}{0} 项}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="搜索" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                                <TextBox x:Name="SearchBox"
                                         Grid.Column="2"
                                         TextChanged="SearchBox_TextChanged"
                                         ToolTip="忽略 -、_、空格；按顺序匹配字符" />
                            </Grid>

                            <ListBox x:Name="AppsList" Grid.Row="2">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="8,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="24" Height="24" CornerRadius="4" Background="#EEF2F7" VerticalAlignment="Center">
                                                    <Grid>
                                                        <Image Source="{Binding Icon}" Width="20" Height="20" Stretch="Uniform" />
                                                        <TextBlock Text="{Binding IconText}"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#667085"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#1F2937" />
                                                        <Border Background="#EEF2F7"
                                                                CornerRadius="4"
                                                                Padding="5,2"
                                                                VerticalAlignment="Center"
                                                                Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding KindText}"
                                                                       FontSize="10"
                                                                       Foreground="#475467" />
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Detail}" FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Grid>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                                                <Button Content="{Binding PrimaryActionText}"
                                                        Click="EditAppButton_Click"
                                                        MinWidth="56"
                                                        MinHeight="28"
                                                        Padding="10,4"
                                                        Background="#EEF2F7"
                                                        Foreground="#1F2937"
                                                        Margin="0,0,6,0" />
                                                <Button Content="删除"
                                                        Click="RemoveAppButton_Click"
                                                        MinWidth="52"
                                                        MinHeight="28"
                                                        Padding="10,4"
                                                        Background="#FEE4E2"
                                                        Foreground="#B42318" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>

                    <TabItem Header="运行信息">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="模式" FontWeight="SemiBold" />
                                <TextBlock Text="Direct relay" Foreground="{StaticResource MutedTextBrush}" Margin="0,3,0,10" />

                                <TextBlock Text="协议" FontWeight="SemiBold" />
                                <TextBlock Text="IPv4 TCP / IPv4 UDP / IPv6 TCP / IPv6 UDP"
                                           Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,3,0,10" />

                                <TextBlock Text="核心进程" FontWeight="SemiBold" />
                                <TextBlock x:Name="CoreProcessText"
                                           Text="未运行"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,10" />

                                <TextBlock Text="网络占用观察" FontWeight="SemiBold" />
                                <TextBlock x:Name="NetworkOwnerHintText"
                                           Text="启动后查看核心进程，而不是 UI 进程。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,10" />

                                <TextBlock Text="配置文件" FontWeight="SemiBold" />
                                <TextBlock x:Name="ConfigPathText" Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" Margin="0,3,0,10" />
                            </StackPanel>

                            <Button Content="重新载入配置" Click="ReloadButton_Click"
                                    Grid.Row="1"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Right"
                                    Background="#EEF2F7" Foreground="#1F2937" />
                        </Grid>
                    </TabItem>

                    <TabItem Header="日志">
                        <Grid Margin="12">
                            <ListBox x:Name="LogList"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1" />
                        </Grid>
                    </TabItem>
                </TabControl>

                <DockPanel Grid.Row="1" Margin="12,0,12,12" LastChildFill="False">
                    <TextBlock Text="核心 relay 流量"
                               FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <TextBlock x:Name="TrafficUploadText"
                                   Text="↑ 0 B/s · 0 B"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="#475467"
                                   Margin="0,0,16,0" />
                        <TextBlock x:Name="TrafficDownloadText"
                                   Text="↓ 0 B/s · 0 B"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="#475467" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

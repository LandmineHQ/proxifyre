<Window x:Class="ProxiFyre.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ProxiFyre Direct Relay" Height="660" Width="960"
        MinHeight="600" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FA">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#667085" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D8DEE8" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#16803C" />
        <SolidColorBrush x:Key="DangerBrush" Color="#C73535" />

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelStyle}" Padding="14" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="ProxiFyre Direct Relay" FontSize="21" FontWeight="SemiBold" Foreground="#1F2937" />
                    <TextBlock Text="Direct traffic relay for selected Windows applications"
                               FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="StatusBadge" Padding="10,6" CornerRadius="16" Background="#EEF2F7" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#98A2B3" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock x:Name="StatusText" Text="已暂停" FontWeight="SemiBold" Foreground="#475467" />
                        </StackPanel>
                    </Border>

                    <Button x:Name="StartStopButton"
                            Width="118"
                            Click="StartStopButton_Click"
                            Background="{StaticResource SuccessBrush}"
                            Foreground="White">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Path x:Name="StartStopIcon"
                                  Width="14" Height="14"
                                  Fill="White"
                                  Stretch="Uniform"
                                  Data="M 2 1 L 13 7 L 2 13 Z"
                                  Margin="0,0,8,0" />
                            <TextBlock x:Name="StartStopButtonText" Text="启用" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelStyle}" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="核心进程名" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4" />
                    <TextBox x:Name="CoreProcessNameInput" ToolTip="用于核心进程自排除；默认 steamwebhelper.exe" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="自定义规则" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4" />
                    <TextBox x:Name="AppInput" ToolTip="例如 chrome.exe，或完整 exe 路径" />
                </StackPanel>

                <Button Grid.Column="4" Content="添加" Click="AddButton_Click" VerticalAlignment="Bottom"
                        Background="#2563EB" Foreground="White" />
                <Button Grid.Column="6" Content="浏览..." Click="BrowseButton_Click" VerticalAlignment="Bottom"
                        Background="#EEF2F7" Foreground="#1F2937" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelStyle}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="应用规则" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ElementName=AppsList, Path=Items.Count, StringFormat={}{0} 项}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   HorizontalAlignment="Right" />
                    </DockPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="搜索" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                        <TextBox x:Name="SearchBox"
                                 Grid.Column="2"
                                 TextChanged="SearchBox_TextChanged"
                                 ToolTip="忽略 -、_、空格；按顺序匹配字符" />
                    </Grid>

                    <ListBox x:Name="AppsList" Grid.Row="2">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="24" Height="24" CornerRadius="4" Background="#EEF2F7" VerticalAlignment="Center">
                                        <Grid>
                                            <Image Source="{Binding Icon}" Width="20" Height="20" Stretch="Uniform" />
                                            <TextBlock Text="{Binding IconText}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="#667085"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#1F2937" />
                                        <TextBlock Text="{Binding Detail}" FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            Background="#EEF2F7"
                                            CornerRadius="4"
                                            Padding="6,3"
                                            VerticalAlignment="Center"
                                            Margin="8,0,0,0">
                                        <TextBlock Text="{Binding KindText}"
                                                   FontSize="11"
                                                   Foreground="#475467" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Grid.Row="3" Content="移除选中项" Click="RemoveSelectedAppButton_Click"
                            HorizontalAlignment="Right" Margin="0,8,0,0"
                            Background="#FEE4E2" Foreground="#B42318" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelStyle}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="运行信息" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10" />

                        <TextBlock Text="模式" FontWeight="SemiBold" />
                        <TextBlock Text="Direct relay" Foreground="{StaticResource MutedTextBrush}" Margin="0,3,0,10" />

                        <TextBlock Text="协议" FontWeight="SemiBold" />
                        <TextBlock Text="IPv4 TCP / IPv4 UDP / IPv6 TCP / IPv6 UDP"
                                   Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,3,0,10" />

                        <TextBlock Text="配置文件" FontWeight="SemiBold" />
                        <TextBlock x:Name="ConfigPathText" Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap" Margin="0,3,0,10" />
                    </StackPanel>

                    <Button Content="重新载入配置" Click="ReloadButton_Click"
                            Grid.Row="1"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Stretch"
                            Background="#EEF2F7" Foreground="#1F2937" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource PanelStyle}" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="日志" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ListBox x:Name="LogList" Grid.Row="1"
                         FontFamily="Consolas"
                         FontSize="12"
                         BorderBrush="{StaticResource BorderBrush}"
                         BorderThickness="1" />
            </Grid>
        </Border>
    </Grid>
</Window>

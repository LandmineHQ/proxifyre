<UserControl x:Class="ProxiFyre.RuntimeInfoTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#667085" />

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="模式" FontWeight="SemiBold" />
            <TextBlock Text="Direct relay"
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,3,0,10" />

            <TextBlock Text="协议" FontWeight="SemiBold" />
            <TextBlock Text="IPv4 TCP / IPv4 UDP / IPv6 TCP / IPv6 UDP"
                       Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,3,0,10" />

            <TextBlock Text="模组目标进程" FontWeight="SemiBold" />
            <TextBlock x:Name="CoreProcessText"
                       Text="未运行"
                       Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,3,0,10" />

            <TextBlock Text="网络占用观察" FontWeight="SemiBold" />
            <TextBlock x:Name="NetworkOwnerHintText"
                       Text="载入后查看目标进程，而不是 UI 进程。"
                       Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,3,0,10" />

            <TextBlock Text="配置文件" FontWeight="SemiBold" />
            <TextBlock x:Name="ConfigPathText"
                       Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,3,0,10" />
        </StackPanel>

        <Button Content="重载模组配置"
                Click="ReloadButton_Click"
                Grid.Row="1"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Background="#EEF2F7"
                Foreground="#1F2937" />
    </Grid>
</UserControl>
